# ============================================
# Terraform .gitignore
# ============================================

# Local .terraform directories
**/.terraform/*
*.terraform.lock.hcl

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup
*.tfstate.lock.info

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# Terraform plan files
*.tfplan
*.tfplan.json

# Variable files (except for examples)
*.tfvars
*.tfvars.json
!.tfvars.example
!.tfvars.json.example

# Terragrunt files (if using Terragrunt)
**/.terragrunt-cache/

# Terraform debug files
terraform.log
terraform.log.*

# ============================================
# Ansible .gitignore
# ============================================

# Ansible temporary files
*.retry
*.tmp
*.temp

# Ansible inventory files (except examples)
inventory/
hosts.ini
!inventory.example
!hosts.example.ini

# Ansible vault files
*.vault
*.vault.yml
*.vault.yaml
vault.yml
vault.yaml

# Ansible collections
collections/
.ansible/collections/

# Ansible roles from Galaxy
roles/geerlingguy.*
roles/*/meta/.galaxy_install_info

# Ansible dynamic inventory scripts output
*.cache
*.json.tmp

# Ansible fact cache
facts.d/
.cache/

# Ansible configuration files with secrets
ansible.cfg
!ansible.example.cfg
ansible.cfg.bak

# Ansible ssh keys
*.pem
*.key
*.ppk
id_rsa*
id_ecdsa*
id_ed25519*

# Ansible logs
ansible.log
ansible-*.log

# Galaxy requirements lock files
galaxy-requirements.yml.lock
requirements.yml.lock

# ============================================
# Common files and directories
# ============================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
desktop.ini

# IDE files
.vscode/
.idea/
*.sublime-*
.project
.classpath
.settings/
*.iml

# Python (for Ansible modules)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.env
.venv
*.egg-info/
dist/
build/

# Logs
*.log
*.log.*

# Backup files
*.bak
*.backup
*.old
*.orig

# Secret files
*.secret
*.secrets
secrets/
.credentials
credentials.yml
.env.local

# Local test files
test/
tests/_temp/
testing/

# Vagrant (if used with Ansible)
.vagrant/

# Packer (if used with Terraform)
*.packer.json
packer_cache/

# Output directories
output/
build/
dist/
artifacts/

# Configuration files with local overrides
*local*
*.local
*-local

# ============================================
# Project-specific patterns
# ============================================

# Python bytecode
*.pyc

# Node modules (if using Terraform CDK)
node_modules/

# Go workspace (if using Terraform providers)
go.work
go.work.sum

# Terraform CDK
cdktf.out/
cdktf.log