set dotenv-load

# Default: show available commands
default:
    @just --list

# Generate a fresh SSH key pair for the migration instance
generate-ssh-key:
    #!/usr/bin/env bash
    set -euo pipefail
    KEY=~/.ssh/id_ed25519
    if [ -f "$KEY" ]; then
        echo "Key already exists: $KEY"
        echo "Delete it first if you want to regenerate."
    else
        ssh-keygen -t ed25519 -f "$KEY" -N "" -C "migration-instance"
        echo "Generated: $KEY and $KEY.pub"
    fi

# Run terraform init
tf-init:
    cd terraform && terraform init

# Run terraform plan
tf-plan:
    cd terraform && terraform plan -var-file terraform-dev.tfvars

# Run terraform apply
tf-apply:
    cd terraform && terraform apply -var-file terraform-dev.tfvars -auto-approve

# Run terraform destroy
tf-destroy:
    cd terraform && terraform destroy -var-file terraform-dev.tfvars -auto-approve

# Save the instance public IP from terraform output
save-instance-ip:
    #!/usr/bin/env bash
    set -euo pipefail
    prometheus_IP=$(cd terraform && terraform output -raw prometheus_public_ip)
    app_IP=$(cd terraform && terraform output -raw app_server_public_ip)
    grafana_IP=$(cd terraform && terraform output -raw grafana_public_ip)
    if [ -z "$prometheus_IP" ]; then
        echo "ERROR: No prometheus IP found. Did you run 'just tf-apply'?"
        exit 1
    fi
    if [ -z "$app_IP" ]; then
        echo "ERROR: No app IP found. Did you run 'just tf-apply'?"
        exit 1
    fi
    if [ -z "$grafana_IP" ]; then
        echo "ERROR: No grafana IP found. Did you run 'just tf-apply'?"
        exit 1
    fi
    echo "$prometheus_IP" > ansible/prometheus_ip.txt
    echo "$app_IP" > ansible/app_ip.txt
    echo "$grafana_IP" > ansible/grafana_ip.txt
    echo "Saved prometheus IP: $prometheus_IP"
    echo "Saved app IP: $app_IP"
    echo "Saved grafana IP: $grafana_IP"

# Generate ansible inventory from the saved IP
update-inventory: save-instance-ip
    #!/usr/bin/env bash
    set -euo pipefail
    prometheus_IP=$(cat ansible/prometheus_ip.txt)
    app_IP=$(cat ansible/app_ip.txt)
    grafana_IP=$(cat ansible/grafana_ip.txt)
    cat > ansible/inventory.yml << EOF
    all:
      hosts:
        prometheus:
          ansible_host: ${prometheus_IP}
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/id_ed25519
          ansible_ssh_common_args: '-o StrictHostKeyChecking=no'
        app:
          ansible_host: ${app_IP}
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/id_ed25519
          ansible_ssh_common_args: '-o StrictHostKeyChecking=no'
        grafana:
          ansible_host: ${grafana_IP}
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/id_ed25519
          ansible_ssh_common_args: '-o StrictHostKeyChecking=no'
    EOF
    echo "Generated ansible/inventory.yml"
    cat ansible/inventory.yml

# Run ansible provisioning playbook
run-ansible:    
    ../05.migration/.venv/bin/ansible-playbook -i ansible/inventory.yml ansible/app_provision.yml
    ../05.migration/.venv/bin/ansible-playbook -i ansible/inventory.yml ansible/grafana_provision.yml
    ../05.migration/.venv/bin/ansible-playbook -i ansible/inventory.yml ansible/prometheus_provision.yml

# SSH into the migration instance
ssh-instance:
    #!/usr/bin/env bash
    set -euo pipefail
    prometheus_IP=$(cat ansible/prometheus_ip.txt)
    app_IP=$(cat ansible/app_ip.txt)
    grafana_IP=$(cat ansible/grafana_ip.txt)
    ssh -i ~/.ssh/id_ed25519 \
        -o StrictHostKeyChecking=no \
        "ubuntu@${prometheus_IP}"
    ssh -i ~/.ssh/id_ed25519 \
        -o StrictHostKeyChecking=no \
        "ubuntu@${app_IP}"        
    ssh -i ~/.ssh/id_ed25519 \
        -o StrictHostKeyChecking=no \
        "ubuntu@${grafana_IP}"          

# Full setup: generate key, init terraform, apply, update inventory, provision
setup: tf-init tf-apply update-inventory run-ansible
    @echo "Migration instance is ready. Run 'just ssh-instance' to connect."
